# Production env for docker-compose (goal 8). Copy to `.env.prod`, fill in, keep secret.
# `.env*` is gitignored — never commit the filled version.

# ── Domain / TLS ──────────────────────────────────────────────────────────────
# The hostname Caddy gets a Let's Encrypt cert for and the app is served at.
DASHBOARD_DOMAIN=dashboard.example.com

# ── OAuth (web client) ────────────────────────────────────────────────────────
# Must exactly match an Authorized redirect URI on the Google web OAuth client.
OAUTH_REDIRECT_URI=https://dashboard.example.com/auth/callback
# Where /auth/callback sends the browser after sign-in (same origin in prod).
FRONTEND_ORIGIN=https://dashboard.example.com
# The client_secret.json (web client) is mounted into the container by compose;
# CLIENT_SECRET_PATH defaults to the repo-root file, leave unset for the mount.

# ── Secrets (generate fresh, keep private) ────────────────────────────────────
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-long-random
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=change-me-fernet-key
# The one account bootstrapped as superuser (always allowed; edits the invite list).
SUPERUSER_EMAIL=you@gmail.com
# One app-level key pays for everyone's Haiku routing.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Scheduler backstop interval (seconds); inline routing is the primary path.
# ROUTER_SCHEDULER_INTERVAL=900
# Nightly backups to keep.
# BACKUP_KEEP=14
